# ─── TELEGRAM BOT CONFIGURATION ───────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"
# Your personal Telegram Chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID="your-telegram-chat-id-here"

# ─── OPENROUTER API (FREE MODELS) ─────────────────────────────────────────────
# Sign up at https://openrouter.ai — free tier is sufficient
OPENROUTER_API_KEY="your-openrouter-api-key-here"

# ─── GMAIL SMTP CONFIGURATION ─────────────────────────────────────────────────
# Use a Gmail App Password (NOT your real password)
# Enable 2FA on your Google account, then generate at:
# https://myaccount.google.com/apppasswords
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-gmail-app-password-here"

# ─── PATHS TO YOUR ATTACHMENTS ────────────────────────────────────────────────
# Full paths to the files you want attached to every outreach email
CV_PATH="/home/your_username/aurora-agent/Your_CV.pdf"
TRANSCRIPT_PATH="/home/your_username/aurora-agent/Your_Transcript.pdf"

# ─── DEADLINE TRACKER SYSTEM ──────────────────────────────────────────────────
# Options: 'json' (local file), 'google_calendar', 'notion', 'none'
DEADLINE_TRACKER_TYPE="json"

# (Optional) Notion Integration
NOTION_API_KEY=""
NOTION_DATABASE_ID=""

# (Optional) Google Calendar Integration
GOOGLE_CALENDAR_CREDENTIALS_PATH="credentials.json"

# ─── PERSONA CUSTOMIZATION ────────────────────────────────────────────────────
AGENT_NAME="Aurora"
USER_NAME="User"
USER_TIMEZONE="UTC"
